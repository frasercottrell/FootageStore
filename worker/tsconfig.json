{
  "compilerOptions": {
    "target": "ES2017",
    "module": "commonjs",
    "lib": ["esnext"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "outDir": "./dist",
    "rootDir": "..",
    "paths": {
      "@/*": ["../src/*"]
    },
    "baseUrl": "."
  },
  "include": ["./**/*.ts", "../src/lib/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
